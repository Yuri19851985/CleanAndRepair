@using Microsoft.AspNet.Identity
@if (Request.IsAuthenticated)
{
    using (Html.BeginForm("LogOff", "Account", FormMethod.Post, new { id = "logoutForm" }))
    {
        @Html.AntiForgeryToken()
        <ul class="nav navbar-nav navbar-right">
            <li><a href="javascript:document.getElementById('logoutForm').submit()">Выход</a></li>
        </ul>
        <ul class="nav navbar-nav navbar-right">
            <li class="dropdown">
                <a id="drop1" href="#" class="dropdown-toggle" data-toggle="dropdown">
                    Здравствуйте @User.Identity.GetUserName()!
                    <span class="caret"></span>
                </a>
                <ul class="dropdown-menu">
                    @if (User.IsInRole("worker"))
                {
                <li><a href="/Index/Manage">Список заказов</a></li>
                <li><a href="/Manage/OrderListIdentityUser">Достижения</a></li>
}
else if (User.IsInRole("admin"))
{
                <li><a href="/Admin/UserList">Список пользователей</a></li>
                <li><a href="/Admin/WorkerList">Список работников</a></li>
                <li><a href="/Admin/ServiceList">Справочник услуг</a></li>
                <li><a href="/Admin/GroupList">Справочник групп</a></li>
}
else
{
                <li><a href="/Index/Manage">Профиль</a></li>
                <li><a href="/Manage/OrderListIdentityUser">Мои заказы</a></li>
}
                </ul>
            </li>
        </ul>
    }
}
else
{
    <ul class="nav navbar-nav navbar-right">
        <li>@Html.ActionLink("Регистрация", "Register", "Account", routeValues: null, htmlAttributes: new { id = "registerLink" })</li>
        <li>@Html.ActionLink("Войти", "Login", "Account", routeValues: null, htmlAttributes: new { id = "loginLink" })</li>
    </ul>
}

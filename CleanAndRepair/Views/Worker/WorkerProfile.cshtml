@model CleanAndRepair.Models.ApplicationUser

@{
    ViewBag.Title = "UserProfile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Мой профиль</h2>

<div>
    <hr />
    <div>
        @Html.DisplayName("Место для фото")
    </div>
    <dl class="dl-horizontal">
        <dt>
            @Html.DisplayName("Имя")
        </dt>

        <dd>
            @Html.DisplayFor(model => model.UserName)
        </dd>
        <dt>
            @Html.DisplayName("Email")
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Email)
        </dd>

        <dt>
            @Html.DisplayName("Телефон")
        </dt>

        <dd>
            @Html.DisplayFor(model => model.PhoneNumber)
        </dd>

        <dt>
            @Html.DisplayName("Рейтинг")
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Raiting)
        </dd>
    </dl>
</div>
<p>
    @Html.ActionLink("Изменить профиль", "EditProfile") |
    @Html.ActionLink("Перейти к заказам", "OrderListIdentityUser")
</p>

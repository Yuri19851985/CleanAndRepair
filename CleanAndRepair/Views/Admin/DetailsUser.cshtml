@model CleanAndRepair.ViewModels.UserDetailsViewModel

@{
    ViewBag.Title = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Информация о рабочем</h2>


<table class="table">
    <tr>
        <th>
            @Html.DisplayFor(m => m.worker.Name)
        </th>
    </tr>
    <tr>
        <th>
            @Html.DisplayName("Здесь будет фото")
        </th>
    </tr>
</table>

@if (Model.Orders.Count() == 0)
{
    <h2>Список заказов пуст</h2>
}
else
{
    <table class="table">
        <tr>
            <th>
                @Html.DisplayName("Дата выполнения")
            </th>
            <th>
                @Html.DisplayName("Услуга")
            </th>
            <th>
                @Html.DisplayName("Адрес")
            </th>
            <th>
                @Html.DisplayName("Телефон клиента")
            </th>
            <th></th>
        </tr>

        @foreach (var item in Model.Orders)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.DateOrderComplete)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ServiceOrder.Name)
                <td>
                    @Html.DisplayFor(modelItem => item.User.Address)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.User.PhoneNumber)
                </td>
                <td>
                    @Html.ActionLink("Удалить", "DeleteOrder", "User", new { id = item.Id })
                </td>
            </tr>
        }

    </table>
}


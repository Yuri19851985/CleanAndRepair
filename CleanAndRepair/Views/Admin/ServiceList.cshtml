@model IEnumerable<CleanAndRepair.Models.Service>

@{
    ViewBag.Title = "Список услуг";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Список услуг</h2>

<p>
    @Html.ActionLink("Добавить новую", "CreateService")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayName("Название")
        </th>
        <th>
            @Html.DisplayName("Группа")
        </th>
        <th>
            @Html.DisplayName("Цена за единицу")
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.Name)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Group.Name)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Price)
        </td>
        <td>
            @Html.ActionLink("Изменить", "EditService", new { id = item.Id }) |
            @Html.ActionLink("Удалить", "DeleteService", new { id = item.Id })
        </td>
    </tr>
}

</table>

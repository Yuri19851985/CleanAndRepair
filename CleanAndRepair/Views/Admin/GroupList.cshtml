@model IEnumerable<CleanAndRepair.Models.GroupService>

@{
    ViewBag.Title = "Группы";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Список групп</h2>

<p>
    @Html.ActionLink("Добавить новую", "CreateGroup")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayName("Id")
        </th>
        <th>
            @Html.DisplayName("Группа")
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.Id)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Name)
        </td>
        <td>
            @Html.ActionLink("Изменить", "EditGroup", new { id = item.Id }) |
            @Html.ActionLink("Удалить", "DeleteGroup", new { id = item.Id })
        </td>
    </tr>
}

</table>

@model CleanAndRepair.Models.Service

@{
    ViewBag.Title = "Редактированние услуги";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<title>Редактирование услуги</title>

<h2>Редактированние услуги</h2>

@using (Html.BeginForm("EditService", "Admin", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <hr />
        @if (ViewBag.Message != null)
        {
            @Html.Label((string)ViewBag.Message, htmlAttributes: new { @class = "text-danger" })
        }
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        <div class="form-group">
            @Html.Label("Название услуги", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger" })
            </div>
        </div>
        <div class="form-group">
            @Html.Label("Цена за нормочас", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(model => model.Price, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.Price, "", new { @class = "text-danger" })
            </div>
        </div>
        <div class="dropdown">
            @Html.Label("Группа", htmlAttributes: new { @class = "control-label col-md-2" })
            @Html.DropDownListFor(model => model.Group.Id, ViewBag.GroupList as SelectList)
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Сохранить" class="btn btn-default" />
            </div>
        </div>
    </div>
}

<div>
    @Html.ActionLink("Вернуться ксписку", "Index")
</div>

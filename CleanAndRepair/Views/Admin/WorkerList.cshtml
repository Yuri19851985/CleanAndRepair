@model IEnumerable<CleanAndRepair.ViewModels.WorkerListViewModel>

@{
    ViewBag.Title = "Работники";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Работники</h2>

<p>
    @Html.ActionLink("Добавить нового", "CreateWorker")
</p>
@if (Model.Count() == 0)
{
    <h4>Список работников пуст</h4>
}
else
{
    <table class="table">
        <tr>
            <th>
                @Html.DisplayName("Имя специалиста")
            </th>
            <th>
                @Html.DisplayName("Рейтинг")
            </th>
            <th>
                @Html.DisplayName("Заказы, шт")
            </th>
            <th>
                @Html.DisplayName("Телефон")
            </th>
            <th></th>
        </tr>

        @foreach (var item in Model)
        {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.worker.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.worker.Raiting)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CountOrders)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.worker.Phone)
            </td>
            <td>
                @Html.ActionLink("Изменить", "EditWorker", new { id = item.worker.Id }) |
                @Html.ActionLink("Подробности", "DetailsWorker", new { id = item.worker.Id }) |
                @Html.ActionLink("Удалить", "DeleteWorker", new { id = item.worker.Id })
            </td>
        </tr>
        }

    </table>
}

@model CleanAndRepair.Models.CalcCleanParametres

@using (Html.BeginForm("Заказать услугу", "Book", FormMethod.Post))
{
    <div>
        <dl class="dl-horizontal">
            <dt> Площадь помещения</dt>
            <dd>
                @Html.EditorFor(m => m.RoomSquare)
                @Html.Label("кв м")
            </dd>
            <dd><br /></dd>
            <dt> Количество комнат</dt>
            <dd>
                @Html.EditorFor(m => m.CountRooms)
            </dd>
            <dd><br /></dd>
            <dt> Степень загрязнения</dt>
            <dd>
                @Html.CheckBoxFor(m => m.Strong)
                @Html.Label("Сильная")
                @Html.CheckBoxFor(m => m.Medium)
                @Html.Label("Умеренная")
                @Html.CheckBoxFor(m => m.Easy)
                @Html.Label("Легкая")
            </dd>
        </dl>
    </div>
    <div class="col-md-offset-2 col-md-10">
        <input type="submit" value="Заказать услугу" class="btn btn-default" />
    </div>
}

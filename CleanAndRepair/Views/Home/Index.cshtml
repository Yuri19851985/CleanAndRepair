@model IEnumerable<DAL.Entities.GroupService>
@{
    Layout = null;
}

<!DOCTYPE html>


    <title>Список сервисов</title>

    <h3>Категории услуг</h3>
    <div>
        <ul>
            @foreach (var g in Model)
            {
                <li>@Ajax.ActionLink(g.Name, "ShowServices", new { id = g.Id }, new AjaxOptions { UpdateTargetId = "groupservice" })</li>
            }
        </ul>
    </div>
    <br />
    <div id="groupservice"> </div>
    @Scripts.Render("~/scripts/jquery-1.10.2.min.js")
    @Scripts.Render("~/scripts/jquery.unobtrusive-ajax.min.js")



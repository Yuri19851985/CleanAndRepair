@model CleanAndRepair.ViewModels.CalcCleanViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Подтверждение заказа";
}
@using (Html.BeginForm("BookService", "Home", FormMethod.Post))
{
    <h2 class="col-md-offset-2">Заказ услуги</h2>
    <div>
        <hr />
        <dl class="dl-horizontal">
            <dt>
                @Html.DisplayFor(m => m.Service.Name)
            </dt>
            <dd>
                Описание услуги с фотографиями
            </dd>
            <dd><hr /></dd>
        </dl>
    </div>

    @Html.HiddenFor(m => m.Service.Id)
    @Html.HiddenFor(m => m.Service.Price)
    @Html.HiddenFor(m => m.Service.Name)
    @Html.HiddenFor(m => m.Service.Group)


    <h4 class="col-md-offset-1">Параметры заказа</h4>
    <hr />
    <div>
        <dl class="dl-horizontal">
            <dt> Выберите удобную для Вас дату</dt>
            <dd>
                @Html.EditorFor(m => m.DateComplete, new { htmlAttributes = new { @type = "date", @name = "date", @id = "dateCompleteField" } })
                @Html.ValidationMessageFor(m => m.DateComplete, "", new { @class = "text-danger" })
            </dd>
            <dd><br /></dd>
            
        </dl>
    </div>
    <div class="col-md-offset-2 col-md-10">
        <input type="submit" value="Заказать услугу" class="btn btn-default" />
    </div>
}
<div class="col-md-offset-1">
    @Html.ActionLink("Вернуться на главную", "Index")
</div>
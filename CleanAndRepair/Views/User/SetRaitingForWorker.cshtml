@model CleanAndRepair.Models.Order

@{
    ViewBag.Title = "SetRaitingForWorker";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>SetRaitingForWorker</h2>

<div>
    <h4>Оценка работы</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>
            Оцените работу специалиста от 1 до 5:
        </dt>
        <dd>
            @using (Html.BeginForm("SetRaitingForWorker", "User", FormMethod.Post))
            {
                @Html.HiddenFor(model => model.Id)

                @Html.EditorFor(model => model.UserSetRaiting)

                <input type="submit" value="Оценить" class="btn btn-default" />
            }
        </dd>
    </dl>
</div>
<p>
    @Html.ActionLink("Назад к списку", "OrderListIdentityUser")
</p>
